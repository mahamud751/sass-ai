# Database (PostgreSQL)
# Update with your own Postgres credentials
# Example:
#   createdb -U YOUR_USER -O YOUR_USER lifemate
DATABASE_URL="postgresql://pino:2742@localhost:5432/lifemate?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OpenAI-compatible (or any LLM)
OPENAI_API_KEY=sk-your-openai-or-compatible-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# App
PORT=3001
NODE_ENV=development

# File Upload
UPLOAD_DIR=./uploads

# Exact PDF↔DOC conversion (optional — auto-detected on Mac)
# LIBREOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice